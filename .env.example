# ─────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────
# LLM / Agent settings (optional — defaults shown)
# ─────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.0
GROQ_MAX_TOKENS=600
GROQ_MAX_RETRIES=3
GROQ_RETRY_BACKOFF=5.0

# ─────────────────────────────────────────────
# Retrieval settings (optional — defaults shown)
# ─────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
CHUNK_CHARS=1200
OVERLAP_CHARS=200
MIN_SCORE=0.25
RETRIEVAL_TOP_K=6
COMPANY_BOOST=1.5

# Hybrid retrieval: 1.0=pure semantic, 0.0=pure keyword
HYBRID_ALPHA=0.7

# ─────────────────────────────────────────────
# Chat agent settings (optional — defaults shown)
# ─────────────────────────────────────────────
# Number of previous conversation turns to send to the LLM for multi-turn memory
CHAT_HISTORY_TURNS=6

# ─────────────────────────────────────────────
# Escalation pattern extension (optional)
# Add semicolon-separated regex patterns to extend defaults
# ─────────────────────────────────────────────
# ESCALATION_INJECTION_EXTRA=pattern1;pattern2
# ESCALATION_MALICIOUS_EXTRA=
# ESCALATION_FRAUD_EXTRA=
# ESCALATION_PII_EXTRA=
# ESCALATION_HARM_EXTRA=
# ESCALATION_SENSITIVE_EXTRA=
# ESCALATION_OUTAGE_EXTRA=

# ─────────────────────────────────────────────
# Debug (optional)
# ─────────────────────────────────────────────
# DEBUG_RUN_ID=my-run-001
